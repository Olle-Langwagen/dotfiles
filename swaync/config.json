{
  "$schema": "/etc/xdg/swaync/configSchema.json",
  "positionX": "right",
  "positionY": "top",
  "layer": "top",
  "control-center-margin-top": 5,
  "control-center-margin-bottom": 5,
  "control-center-margin-right": 5,
  "control-center-margin-left": 5,
  "notification-icon-size": 48,
  "notification-body-image-height": 60,
  "notification-body-image-width": 120,
  "timeout": 6,
  "timeout-low": 3,
  "timeout-critical": 0,
  "fit-to-screen": true,
  
  "control-center-width": 320,
  "control-center-height": 450,
  "notification-window-width": 320,
  
  "keyboard-shortcuts": true,
  "image-visibility": "always",
  "transition-time": 150,
  "hide-on-clear": true,
  "pause-level-low": false,
  "widgets": [
    "title",
    "notifications"
  ],
  "widget-config": {
    "title": {
      "text": "Notiser",
      "clear-all-button": true,
      "button-text": "Rensa"
    }
  }
}
